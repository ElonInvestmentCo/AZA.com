modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["node", "start.mjs"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server run build && NODE_ENV=production pnpm --filter @workspace/website run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PayVora Website"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PayVora API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PAYVORA Mobile"

[[workflows.workflow]]
name = "PayVora Website"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/website run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "PayVora API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run build && cd artifacts/api-server && node --enable-source-maps ./dist/index.mjs"
waitForPort = 8080

[[workflows.workflow]]
name = "PAYVORA Mobile"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CI=1 EXPO_NO_WEB=1 EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN pnpm --filter @workspace/mobile exec expo start --lan --port 8099"
waitForPort = 8099

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 19000
externalPort = 3002

[[ports]]
localPort = 19001
externalPort = 4200

[[ports]]
localPort = 19002
externalPort = 5000

[[ports]]
localPort = 19665
externalPort = 3003

[[ports]]
localPort = 8099
externalPort = 8099

[nix]
channel = "stable-25_05"
packages = ["nano", "lsof"]

[userenv]

[userenv.shared]
PORT = "8080"
EXPO_PUBLIC_DOMAIN = "www.payvora.org"
RELOADLY_ENV = "topup-prod"
NODE_ENV = "development"
INTERNAL_API_URL = "http://localhost:8080"
GOOGLE_CALLBACK_URL = "https://www.payvora.org/api/auth/google/callback"
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID = "419400712274-vioi4kdk4gg41ufsm2brjgtqmr8q2agq.apps.googleusercontent.com"
