modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AZA Mobile"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Payvora Mobile"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "AZA Mobile"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "DANGEROUSLY_DISABLE_HOST_CHECK=true pnpm --filter @workspace/mobile run dev"

[[workflows.workflow]]
name = "Payvora Mobile"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "DANGEROUSLY_DISABLE_HOST_CHECK=true pnpm --filter @workspace/payvora run dev"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 5173

[[ports]]
localPort = 18115
externalPort = 3000

[[ports]]
localPort = 18116
externalPort = 3001

[[ports]]
localPort = 19000
externalPort = 3002

[[ports]]
localPort = 19001
externalPort = 4200

[[ports]]
localPort = 19002
externalPort = 5000

[[ports]]
localPort = 19665
externalPort = 3003

[nix]
channel = "stable-25_05"
packages = ["nano"]

[userenv]

[userenv.shared]
PORT = "8080"
EXPO_PUBLIC_DOMAIN = "www.payvora.org"
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID = "529491115901-mt2b2k6me217h5r11sruunhfingtoetv.apps.googleusercontent.com"
