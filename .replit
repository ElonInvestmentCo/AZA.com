modules = ["nodejs-20", "web", "bash", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["node", "start.mjs"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server run build && NODE_ENV=production pnpm --filter @workspace/website run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PayVora Website"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mobile (Expo)"

[[workflows.workflow]]
name = "PayVora Website"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "INTERNAL_API_URL=http://localhost:3001 pnpm --filter @workspace/website run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 node --enable-source-maps ./artifacts/api-server/dist/index.mjs"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Mobile (Expo)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mobile run dev"
waitForPort = 19000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 19000
externalPort = 3002

[[ports]]
localPort = 19001
externalPort = 4200

[[ports]]
localPort = 19002
externalPort = 5000

[[ports]]
localPort = 19665
externalPort = 3003

[nix]
channel = "stable-25_05"
packages = ["nano", "lsof"]

[userenv]

[userenv.shared]
PORT = "8080"
EXPO_PUBLIC_DOMAIN = "www.payvora.org"
RELOADLY_ENV = "topup-prod"
INTERNAL_API_URL = "http://localhost:8080"
GOOGLE_CALLBACK_URL = "https://www.payvora.org/api/auth/google/callback"
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID = "419400712274-vioi4kdk4gg41ufsm2brjgtqmr8q2agq.apps.googleusercontent.com"

[userenv.development]
NODE_ENV = "development"

[userenv.production]
NODE_ENV = "production"
